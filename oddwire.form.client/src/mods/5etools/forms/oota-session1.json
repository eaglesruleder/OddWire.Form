                                        { "controls": [ { "param": "npc", "value": "^" }, { "param": "interactee", "value": "Players" }, { "param": "interaction", "value": "- Draven (13) Kitchen Preparation\n- Susi (12) Armour Maintenance\n- Evan (18) Officer-Quarters Service\n- Leigh? (5) Corpse Retrieval" } ] },
                                        { "controls": [ { "param": "interactee", "value": "Players" }, { "param": "interaction", "value": "* Over few days, aiming 20min a day\n* RP is mainly end of day\n* Day1 sets scene\n- Underdark, chasm, cliff prison\n- Factions\n- Layout\n- Tasks" } ] }
