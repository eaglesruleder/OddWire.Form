                                { "type": "textarea", "param": "d3MorningScene", "label": "Scene", "rows": 4, "value": "The routine breaks for the lift.\nExisting NPCs woken early to assist.\nIntro Derendil, Jimjar, Shuushar, and Topsy & Turvy." },
                                { "type": "label", "param": "d3MorningIntHead", "label": "Interactions" },
                                {
                                    "type": "looper", "param": "d3MorningInt", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "npc", "label": "NPC", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "text", "param": "interactee", "label": "interactee", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "textarea", "param": "interaction", "label": "interaction", "stacked": true, "cellClassName": "sm-col-6" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "npc", "value": "Ront" }, { "param": "interaction", "value": "'Look tough'\nRoll STR intimidate" } ] },
                                        { "controls": [ { "param": "npc", "value": "Bupido" }, { "param": "interaction", "value": "Patdown new inmates.\nRoll Sleight to find Derendils knife\nRoll Deception to keep it" } ] },
                                        { "controls": [ { "param": "npc", "value": "Ilvara" }, { "param": "interaction", "value": "appraises each arrival as property." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interaction", "value": "records names, condition, useful skills and unusual traits." } ] },
                                        { "controls": [ { "param": "npc", "value": "Jorlan" }, { "param": "interaction", "value": "watches Shoor and Ilvara more than he watches the prisoners." } ] },
                                        { "controls": [ { "param": "npc", "value": "Players" }, { "param": "interaction", "value": "Take a task from\n- Security\n- Unloading freight\n- Patdown & Onboard new prisoners\n- Operating lift\n- Managing Quaggoth" } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d3EveningSec", "label": "Evening — A Crowded Cell",
                            "controls": [
                                { "type": "textarea", "param": "d3EveningScene", "label": "Scene", "rows": 5, "value": "The new arrivals join the pen. Don't run four introductions back-to-back — give each a clear first impression, then let the PCs choose who to approach. The original prisoners recap what they know, letting players summarise their discoveries. By the end, the group should start naming possible escape routes rather than gathering isolated facts." },
                                { "type": "label", "param": "d3EveImpHead", "label": "First Impressions" },
                                {
                                    "type": "looper", "param": "d3EveImp", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Derendil — demands to be addressed by his claimed identity." } ] },
                                        { "controls": [ { "param": "info", "value": "Jimjar — offers a wager, or reads the room in a glance." } ] },
                                        { "controls": [ { "param": "info", "value": "Shuushar — asks that no one start a fight while trapped together." } ] },
                                        { "controls": [ { "param": "info", "value": "Topsy & Turvy — quietly clock the exits; dodge questions about themselves." } ] }
                                    ]
                                }
                            ]
                        },
                        { "type": "textarea", "param": "d3Notes", "label": "DM Notes — Day 3", "rows": 4 }
