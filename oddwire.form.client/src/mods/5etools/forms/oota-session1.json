                {
                    "type": "tab",
                    "param": "tabDay4",
                    "label": "Day 4",
                    "controls": [
                        { "type": "textarea", "param": "d4Progress", "label": "Day 4 — Tests of Loyalty", "rows": 2, "value": "Prison progression: Asha probes the prisoners for divisions while Jorlan quietly begins manufacturing an escape opportunity." },
                        {
                            "type": "collapsible", "param": "d4EscapeSec", "label": "Escape Information", "subtitle": "Tick each as the party learns it",
                            "controls": [
                                {
                                    "type": "looper", "param": "d4Escape", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Asha and Ilvara are not fully aligned." } ] },
                                        { "controls": [ { "param": "info", "value": "Jorlan may be willing to undermine Shoor." } ] },
                                        { "controls": [ { "param": "info", "value": "Select chores give access to the shrine, officer areas or guard tower." } ] },
                                        { "controls": [ { "param": "info", "value": "The Drow are actively hunting for the prisoners' leader." } ] },
                                        { "controls": [ { "param": "info", "value": "A tool, key or route may surface through deliberate negligence." } ] },
                                        { "controls": [ { "param": "info", "value": "Jorlan's help is motivated by revenge, not sympathy." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d4MorningSec", "label": "Morning — Asha's Examination",
                            "controls": [
                                { "type": "textarea", "param": "d4MorningScene", "label": "Scene", "rows": 6, "value": "Asha has the prisoners inspected under a pretext — health, religious contamination, inventory — asking questions built to expose alliances and weaknesses, framing cooperation as a way for one prisoner to gain at another's expense. She avoids open threats.\n\nHer questions: Who leads? Who'll betray the others? Who's discussed escape? Who's dangerous? Who's hiding something?" },
                                { "type": "label", "param": "d4MorningIntHead", "label": "Interactions" },
                                {
                                    "type": "looper", "param": "d4MorningInt", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "npc", "label": "NPC", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "text", "param": "interactee", "label": "interactee", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "textarea", "param": "interaction", "label": "interaction", "stacked": true, "cellClassName": "sm-col-6" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interactee", "value": "Sarith" }, { "param": "interaction", "value": "questions Sarith about his disgrace, memory and condition." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interactee", "value": "Ranger" }, { "param": "interaction", "value": "asks the Ranger to name the most suspicious prisoner, testing evidence vs accusation." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interactee", "value": "Cleric" }, { "param": "interaction", "value": "questions the Cleric about their god, undeath and lost identity." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interactee", "value": "Paladin" }, { "param": "interaction", "value": "tries to make the Paladin privately contradict a public statement." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interactee", "value": "Stool" }, { "param": "interaction", "value": "treats Stool as a biological specimen." } ] },
                                        { "controls": [ { "param": "npc", "value": "Buppido" }, { "param": "interaction", "value": "plays cooperative and harmless; may offer plausible-sounding accusations." } ] },
                                        { "controls": [ { "param": "npc", "value": "Topsy & Turvy" }, { "param": "interaction", "value": "become visibly tense if separated or examined." } ] },
                                        { "controls": [ { "param": "npc", "value": "Shuushar" }, { "param": "interaction", "value": "refuses to condemn another prisoner." } ] },
                                        { "controls": [ { "param": "npc", "value": "Eldeth" }, { "param": "interaction", "value": "warns the PCs not to show divisions in front of Asha." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d4MiddaySec", "label": "Midday — Jorlan's Manufactured Opening",
                            "controls": [
                                { "type": "textarea", "param": "d4MiddayScene", "label": "Scene", "rows": 4, "value": "Later, Jorlan oversees a work detail and creates an opening that looks accidental. He never admits he wants an escape — he only lets the prisoners see that Shoor's embarrassment would please him." },
                                { "type": "label", "param": "d4MiddayOptHead", "label": "Possible Openings (pick one)" },
                                {
                                    "type": "looper", "param": "d4MiddayOpts", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Leaving a tool within reach." } ] },
                                        { "controls": [ { "param": "info", "value": "Letting a prisoner see the guard tower interior." } ] },
                                        { "controls": [ { "param": "info", "value": "Assigning a reduced escort." } ] },
                                        { "controls": [ { "param": "info", "value": "Mentioning tomorrow's transport inspection." } ] },
                                        { "controls": [ { "param": "info", "value": "Failing to search a prisoner properly." } ] },
                                        { "controls": [ { "param": "info", "value": "Ordering a guard away at exactly the wrong moment." } ] },
                                        { "controls": [ { "param": "info", "value": "Correcting someone who misreads how the lift controls work." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d4EveningSec", "label": "Evening — Is It a Trap?",
                            "controls": [
                                { "type": "textarea", "param": "d4EveningScene", "label": "Scene", "rows": 3, "value": "The prisoners debate whether Jorlan's apparent help is genuine. The PCs should leave with a provisional plan and a list of what's still missing." },
                                { "type": "label", "param": "d4EvePosHead", "label": "Positions Around the Cell" },
                                {
                                    "type": "looper", "param": "d4EvePos", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Eldeth — use the opening, but cautiously." } ] },
                                        { "controls": [ { "param": "info", "value": "Ront — act immediately." } ] },
                                        { "controls": [ { "param": "info", "value": "Shuushar — hating Shoor doesn't make Jorlan an ally." } ] },
                                        { "controls": [ { "param": "info", "value": "Jimjar — bets Jorlan expects them to try something." } ] },
                                        { "controls": [ { "param": "info", "value": "Sarith — knows enough Drow politics to confirm Jorlan has motive." } ] },
                                        { "controls": [ { "param": "info", "value": "Buppido — use it, but plan to abandon any liability." } ] },
                                        { "controls": [ { "param": "info", "value": "Topsy & Turvy — quietly prepare their own contingency." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d4ReqsSec", "label": "Plan Requirements", "subtitle": "Tick each as the party secures it",
                            "controls": [
                                {
                                    "type": "looper", "param": "d4Reqs", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "A weapon." } ] },
                                        { "controls": [ { "param": "info", "value": "A key or way through the pen gate." } ] },
                                        { "controls": [ { "param": "info", "value": "Knowledge of the lift." } ] },
                                        { "controls": [ { "param": "info", "value": "A distraction." } ] },
                                        { "controls": [ { "param": "info", "value": "Agreement on whether to free every prisoner." } ] },
                                        { "controls": [ { "param": "info", "value": "A route to the confiscated equipment." } ] }
                                    ]
                                }
                            ]
                        },
                        { "type": "textarea", "param": "d4Notes", "label": "DM Notes — Day 4", "rows": 4 }
                    ]
                },
                {
                    "type": "tab",
                    "param": "tabDay5",
                    "label": "Day 5",
                    "controls": [
                        { "type": "textarea", "param": "d5Progress", "label": "Day 5 — Last Chance", "rows": 2, "value": "Prison progression: announce the imminent transfer, tighten security, and force the group to act before their accumulated openings vanish." },
                        {
                            "type": "collapsible", "param": "d5EscapeSec", "label": "Escape Information", "subtitle": "Tick each as the party learns it",
                            "controls": [
                                {
                                    "type": "looper", "param": "d5Escape", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "The prisoners will soon be transferred toward Menzoberranzan." } ] },
                                        { "controls": [ { "param": "info", "value": "Confiscated equipment is moved or prepped for transport." } ] },
                                        { "controls": [ { "param": "info", "value": "Guard routines change during departure prep." } ] },
                                        { "controls": [ { "param": "info", "value": "The lift, gate or outbound route must be opened during processing." } ] },
                                        { "controls": [ { "param": "info", "value": "Shoor's confidence creates a final security mistake." } ] },
                                        { "controls": [ { "param": "info", "value": "Jorlan provides the last opening but won't openly fight for them." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d5MorningSec", "label": "Morning — Prepared for Transport",
                            "controls": [
                                { "type": "textarea", "param": "d5MorningScene", "label": "Scene", "rows": 5, "value": "Ilvara announces the transfer. Work details shorten or redirect to departure prep — packing supplies, moving confiscated goods, checking restraints, preparing the lift, sorting prisoners by value, loading food and water, clearing the route out. Security is tighter, but the outpost is busier and less orderly." },
                                { "type": "label", "param": "d5MorningIntHead", "label": "Interactions" },
                                {
                                    "type": "looper", "param": "d5MorningInt", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "npc", "label": "NPC", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "text", "param": "interactee", "label": "interactee", "stacked": true, "cellClassName": "sm-col-3" },
                                        { "type": "textarea", "param": "interaction", "label": "interaction", "stacked": true, "cellClassName": "sm-col-6" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "npc", "value": "Ilvara" }, { "param": "interactee", "value": "Paladin/leader" }, { "param": "interaction", "value": "orders the Paladin/leader to keep the others compliant; implies cooperation may get some to the city alive." } ] },
                                        { "controls": [ { "param": "npc", "value": "Shoor" }, { "param": "interaction", "value": "stages a public punishment or inspection, massing guards in one spot." } ] },
                                        { "controls": [ { "param": "npc", "value": "Shoor" }, { "param": "interaction", "value": "pulls guards off routine posts to help with transport." } ] },
                                        { "controls": [ { "param": "npc", "value": "Asha" }, { "param": "interaction", "value": "selects a prisoner for further examination, sacrifice or separate transport." } ] },
                                        { "controls": [ { "param": "npc", "value": "Jorlan" }, { "param": "interaction", "value": "gives one precise piece of info, or deliberately leaves the final opening." } ] },
                                        { "controls": [ { "param": "interaction", "value": "The prisoners' confiscated gear becomes visible or briefly reachable." } ] },
                                        { "controls": [ { "param": "npc", "value": "Derendil" }, { "param": "interaction", "value": "harder to control as transport becomes real." } ] },
                                        { "controls": [ { "param": "npc", "value": "Ront" }, { "param": "interaction", "value": "demands immediate action." } ] },
                                        { "controls": [ { "param": "npc", "value": "Eldeth" }, { "param": "interaction", "value": "pushes for a coordinated plan." } ] },
                                        { "controls": [ { "param": "npc", "value": "Jimjar" }, { "param": "interaction", "value": "calls in or offers a final wager." } ] },
                                        { "controls": [ { "param": "npc", "value": "Shuushar" }, { "param": "interaction", "value": "asks whether escape means killing every guard." } ] },
                                        { "controls": [ { "param": "npc", "value": "Topsy & Turvy" }, { "param": "interaction", "value": "refuse to be separated." } ] },
                                        { "controls": [ { "param": "npc", "value": "Stool" }, { "param": "interaction", "value": "frightened; seeks reassurance." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d5OpeningsSec", "label": "Jorlan's Final Openings", "subtitle": "Pick the last opening he leaves",
                            "controls": [
                                {
                                    "type": "looper", "param": "d5Openings", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "The cell door is left incompletely secured." } ] },
                                        { "controls": [ { "param": "info", "value": "A key is placed where a prisoner can reach it." } ] },
                                        { "controls": [ { "param": "info", "value": "A guard rotation is delayed." } ] },
                                        { "controls": [ { "param": "info", "value": "The way to the equipment room is identified." } ] },
                                        { "controls": [ { "param": "info", "value": "Guards are ordered away from the lift." } ] },
                                        { "controls": [ { "param": "info", "value": "Jorlan warns the next inspection is the last chance to act." } ] }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "collapsible", "param": "d5EveningSec", "label": "Evening — The Escape Begins",
                            "controls": [
                                { "type": "textarea", "param": "d5EveningScene", "label": "Scene", "rows": 3, "value": "Ideally there is no peaceful evening on Day 5 — the 'evening' is the moment the prisoners gather, confirm the plan and commit. Let the players decide the specifics." },
                                { "type": "label", "param": "d5EveDecHead", "label": "Player Decisions" },
                                {
                                    "type": "looper", "param": "d5EveDec", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Who is being freed." } ] },
                                        { "controls": [ { "param": "info", "value": "Who carries the limited equipment." } ] },
                                        { "controls": [ { "param": "info", "value": "Whether the lift is an objective, distraction or false route." } ] },
                                        { "controls": [ { "param": "info", "value": "How to handle prisoners who disagree." } ] },
                                        { "controls": [ { "param": "info", "value": "Whether to trust Jorlan's opening." } ] },
                                        { "controls": [ { "param": "info", "value": "What signal begins the escape." } ] }
                                    ]
                                },
                                { "type": "textarea", "param": "d5Demon", "label": "The Demon Attack", "rows": 3, "value": "The demon attack (or another major disruption) can land three ways — and must never solve the escape on its own; it removes Drow control, not the need for player decisions." },
                                {
                                    "type": "looper", "param": "d5DemonWays", "addRows": true,
                                    "controls": [
                                        { "type": "text", "param": "info", "cellClassName": "sm-col-11" },
                                        { "type": "checkbox", "param": "seen", "cellClassName": "sm-col-1" }
                                    ],
                                    "value": [
                                        { "controls": [ { "param": "info", "value": "Player-created opportunity — the party already has a plan; the attack complicates it." } ] },
                                        { "controls": [ { "param": "info", "value": "Escalation — the escape starts, then the attack turns a controlled breakout into chaos." } ] },
                                        { "controls": [ { "param": "info", "value": "Failure valve — the party is discovered or trapped, and the attack creates a second chance." } ] }
                                    ]
                                }
                            ]
                        },
                        { "type": "textarea", "param": "d5Notes", "label": "DM Notes — Day 5", "rows": 4 }
                    ]
                }
            ]
        },
        {
            "type": "tab",
            "param": "tabCast",
            "label": "Cast",
            "controls": [
                { "type": "textarea", "param": "castCaptors", "label": "Captors — The Drow", "rows": 12, "value": "Jorlan (Slavemaster) — stern, observant, efficient rather than cruel. Runs the immediate routine but isn't the outpost's highest authority. Resents Shoor; any 'help' he later gives is revenge, never sympathy.\n\nShoor (Captain) — insecure and cruel, values spectacle over security, easy to bait into overriding Jorlan. Dangerous but visibly dependent on Ilvara's favour.\n\nIlvara (Priestess & Commander) — the outpost's true authority. Appraises prisoners as property; deliberate where Shoor is impulsive. Takes a controlled interest in the Reborn Cleric.\n\nAsha (Priestess's Aide) — catalogues prisoners and probes for divisions under pretexts of health or inventory. Not fully aligned with Ilvara." },
                { "type": "textarea", "param": "castPrisoners", "label": "Fellow Prisoners", "rows": 14, "value": "Ront (Orc) — aggressive, easy to anger, always pushing to fight now.\nEldeth (Shield Dwarf) — practical and observant; pushes coordination and caution, warns against showing divisions.\nBuppido (Derro) — presents as helpful; actually backs whichever argument splits the group most, and would abandon a liability.\nSarith (Drow) — disgraced; avoids the Drow unless ordered. Reads Drow politics and motives.\nStool (Myconid sprout) — simple, immediate friendliness through rapport spores. Easily frightened; seeks reassurance.\nDerendil (Quaggoth) — insists he is an elf prince, not what he appears. Harder to control as transport nears.\nJimjar (Deep Gnome) — compulsive gambler; makes a wager almost immediately and reads a room fast.\nShuushar (Kuo-toa) — pacifist; refuses to condemn others or start fights, questions whether escape means killing every guard.\nTopsy & Turvy (Deep Gnome twins) — stay close, reveal little, clock exits, prepare their own contingency. Refuse to be separated." }
            ]
        }
    ]
}
