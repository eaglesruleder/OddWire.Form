                                    ],
                                    "value": [
                                        { "controls": [ { "param": "npc", "value": "Jorlan" }, { "param": "interaction", "value": "- Drops off 'Goblin Chef' to cell\n- Gonna go over the rules\n-- Next few days gonna do role call & task assignment in morning\n-- Tasks during the day\n-- While out Ilvara tolerates seeing you, so talking to her is defiantly over the line.\n-- LR & NPC RP in the evening\n\n- Takes out imaginary paper reel" } ] },
                                        { "controls": [ { "param": "npc", "value": "^" }, { "param": "interactee", "value": "Buppido" }, { "param": "interaction", "value": "Buppido presents as helpful\nJorlan assigns to (2) Spider-Carrion Disposal\nBuppido excited" } ] },
