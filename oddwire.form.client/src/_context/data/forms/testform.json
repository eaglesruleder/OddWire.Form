{
    "formId": "11111111-1111-4111-8111-111111111111",
    "label": "Contact Form",
    "version": "1.0.1",
    "export": { "api": "/api/form/contact", "pdf": true },
    "displayParam": ["fullName", "email"],
    "controls": [
        { "type": "label", "param": "title", "label": "Contact" },
        { "type": "text", "param": "fullName", "label": "Full name", "value": "Dillon O’Dwyer", "pdf": { "0": [{ "x": 10, "y": 10 }] } },
        { "type": "text", "param": "email", "label": "Email", "value": "", "valueType": "email", "keyboardType": "email" },
        { "type": "text", "param": "age", "label": "Age", "value": "", "valueType": "int", "keyboardType": "numeric" },
        { "type": "textarea", "param": "bio", "label": "Short bio", "value": "IT Coordinator and Software Developer" },
        { "type": "text", "param": "secret", "label": "Should never appear", "value": "hidden", "hidden": true },
        { "type": "checkbox", "param": "subscribed", "label": "Subscribe to updates", "value": true },
        {
            "type": "radio",
            "param": "status",
            "label": "Status",
            "value": "open",
            "controls": [
                { "value": "open", "label": "Open" },
                { "value": "closed", "label": "Closed" }
            ]
        },
        {
            "type": "dropdown",
            "param": "priority",
            "label": "Priority",
            "value": "medium",
            "controls": [
                { "value": "low", "label": "Low" },
                { "value": "medium", "label": "Medium" },
                { "value": "high", "label": "High" }
            ]
        },
        { "type": "slider", "param": "volume", "label": "Volume (unsupported on purpose)", "value": 5 },
        {
            "type": "collapsible",
            "param": "detailsSection",
            "label": "More details",
            "controls": [
                { "type": "text", "param": "company", "label": "Company", "value": "" },
                { "type": "textarea", "param": "notes", "label": "Notes", "value": "" }
            ]
        },
        {
            "type": "popup",
            "param": "evidencePopup",
            "label": "Add evidence",
            "controls": [
                { "type": "text", "param": "evidenceUrl", "label": "Link", "value": "" },
                { "type": "textarea", "param": "evidenceDesc", "label": "Description", "value": "" }
            ]
        },
        {
            "type": "tab",
            "param": "tabContact",
            "label": "Contact",
            "controls": [
                { "type": "text", "param": "phone", "label": "Phone", "value": "", "valueType": "phone", "keyboardType": "tel" }
            ]
        },
        {
            "type": "tab",
            "param": "tabAddress",
            "label": "Address",
            "controls": [
                { "type": "text", "param": "street", "label": "Street", "value": "" },
                { "type": "text", "param": "city", "label": "City", "value": "" }
            ]
        }
    ]
}
