        {
            "type": "tab",
            "param": "tabCombat",
            "label": "Combat",
            "controls": [
                { "type": "textarea", "param": "damageVuln", "label": "Vulnerabilities" },
                { "type": "textarea", "param": "damageRes", "label": "Resistances" },
