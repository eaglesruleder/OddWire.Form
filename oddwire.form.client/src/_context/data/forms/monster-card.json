                    { "type": "text", "param": "deception", "label": "Deception", "stacked": true, "cellClassName": "sm-col-6 lg-col-3" },
                    { "type": "text", "param": "intimidation", "label": "Intimidation", "stacked": true, "cellClassName": "sm-col-6 lg-col-3" },
                    { "type": "text", "param": "performance", "label": "Performance", "stacked": true, "cellClassName": "sm-col-6 lg-col-3" },
